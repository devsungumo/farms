# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Cloudflare R2 — required in production, leave blank in development
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN=media.yourdomain.com

# Social OAuth — callback URLs must match your frontend and each provider's console
# Google: https://console.cloud.google.com → APIs & Services → Credentials
# Facebook: https://developers.facebook.com → App → Facebook Login → Settings
# GitHub: https://github.com/settings/developers → OAuth Apps
#
# OAuth credentials (Client ID & Secret) are configured in Django admin
# under Social Applications — NOT in this file.
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Paystack — added when building the payments app
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
